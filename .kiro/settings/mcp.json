{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "disabled": true,
      "autoApprove": [
        "browser_navigate",
        "browser_type",
        "browser_click",
        "browser_fill_form",
        "browser_evaluate",
        "browser_snapshot",
        "browser_console_messages",
        "browser_wait_for",
        "browser_press_key",
        "browser_tabs",
        "browser_close",
        "browser_select_option",
        "browser_handle_dialog",
        "browser_handle_dialog",
        "browser_file_upload",
        "browser_network_requests",
        "browser_take_screenshot"
      ]
    },
    "knowledge-graph": {
      "command": "npx",
      "args": [
        "-y",
        "git+https@github.com:YUChoe/memory-mcp.git",
        "C:\\Users\\yonguk.choe\\src\\Echoes-of-the-Fallen-Age\\.kiro"
      ],
      "disabled": false,
      "autoApprove": [
        "read_graph",
        "create_entities",
        "create_relations",
        "search_nodes",
        "add_observations",
        "open_nodes",
        "delete_observations"
      ]
    },
    "telnet-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "git+https://github.com/YUChoe/telnet-mcp"
      ],
      "env": {},
      "disabled": true,
      "autoApprove": [
        "telnet_connect",
        "telnet_read",
        "telnet_send",
        "telnet_disconnect",
        "telnet_list"
      ]
    }
  }
}