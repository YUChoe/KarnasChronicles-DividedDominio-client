# 환경 설정 예시
# 실제 사용 시 .env 파일로 복사하여 사용하세요
# cp .env.example .env

# Node 환경
NODE_ENV=production

# WebSocket Gateway 설정
WS_PORT=3000

# Telnet 서버 설정
TELNET_HOST=localhost
TELNET_PORT=4000

# 연결 설정
MAX_CONNECTIONS=200
CONNECTION_TIMEOUT=30000

# 로그 설정
LOG_LEVEL=info

# 클라이언트 설정 (빌드 시 사용)
VITE_WS_URL=ws://localhost:3000
